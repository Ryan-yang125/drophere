{
  "name": "@drophere/cli",
  "version": "1.0.0",
  "description": "Free command-line deployment client for drophere.page",
  "private": true,
  "license": "MIT",
  "homepage": "https://drophere.page",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ryan-yang125/drophere.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "drophere": "./bin/drophere.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node18 --banner:js='#!/usr/bin/env node' --outfile=dist/drophere.js && chmod 755 dist/drophere.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "esbuild": "0.28.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
